; This file is auto-generated by scripts/setup.sh
; Replace SERVER_IP with your actual server IP, or run setup.sh
$ORIGIN routeroot.dev.
$TTL 300

@       IN SOA  ns1.routeroot.dev. admin.routeroot.dev. (
                2026030601  ; serial
                3600        ; refresh
                900         ; retry
                604800      ; expire
                300         ; minimum TTL
)

@       IN NS   ns1.routeroot.dev.
@       IN NS   ns2.routeroot.dev.

; Nameservers
ns1     IN A    SERVER_IP
ns2     IN A    SERVER_IP

; Root domain
@       IN A    SERVER_IP

; API subdomain
api     IN A    SERVER_IP

; Wildcard — all subdomains resolve to this server
*       IN A    SERVER_IP
