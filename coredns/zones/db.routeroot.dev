$ORIGIN routeroot.dev.
$TTL 300

@       IN SOA  ns1.routeroot.dev. admin.routeroot.dev. (
                2024010101  ; serial
                3600        ; refresh
                900         ; retry
                604800      ; expire
                300         ; minimum TTL
)

@       IN NS   ns1.routeroot.dev.
@       IN NS   ns2.routeroot.dev.

; Nameservers — replace with your server IP(s)
ns1     IN A    51.178.209.71
ns2     IN A    51.178.209.71

; Root domain
@       IN A    51.178.209.71

; Wildcard — all subdomains resolve to this server
*       IN A    51.178.209.71
