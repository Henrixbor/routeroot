$ORIGIN routeroot.dev.
$TTL 300

@       IN SOA  ns1.routeroot.dev. admin.routeroot.dev. (
                2026030601  ; serial
                3600        ; refresh
                900         ; retry
                604800      ; expire
                300         ; minimum TTL
)

@       IN NS   ns1.routeroot.dev.
@       IN NS   ns2.routeroot.dev.

; Nameservers
ns1     IN A    91.98.128.171
ns2     IN A    91.98.128.171

; Root domain
@       IN A    91.98.128.171

; API subdomain
api     IN A    91.98.128.171

; Wildcard — all subdomains resolve to this server
*       IN A    91.98.128.171
