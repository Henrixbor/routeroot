# BOOTSTRAP ONLY — This Caddyfile is loaded initially by Caddy, but agent-api
# REPLACES the entire config via Caddy's JSON admin API at startup
# (see proxy.rs::init_caddy_config). Changes here won't persist after startup.
{
    on_demand_tls {
        ask http://agent-api:8053/api/tls-check
    }
    admin :2019
}

# Root domain — serves the API/dashboard
{$ROUTEROOT_DOMAIN:routeroot.dev} {
    reverse_proxy agent-api:8053
}

# API subdomain
api.{$ROUTEROOT_DOMAIN:routeroot.dev} {
    reverse_proxy agent-api:8053
}

# Wildcard — on-demand TLS for deployment subdomains
# No handler: falls through so admin API routes handle requests
*.{$ROUTEROOT_DOMAIN:routeroot.dev} {
    tls {
        on_demand
    }
}
