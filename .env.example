# AgentDNS Configuration
# Copy to .env and edit values

# Required
AGENTDNS_DOMAIN=agentdns.dev
AGENTDNS_SERVER_IP=127.0.0.1
AGENTDNS_API_KEY=change-me-to-a-secure-key

# Optional
AGENTDNS_MAX_DEPLOYMENTS=20
AGENTDNS_DEFAULT_TTL=48h
AGENTDNS_MAX_MEMORY=2048
AGENTDNS_MAX_CPUS=2
AGENTDNS_LOG_FORMAT=human
AGENTDNS_GITHUB_WEBHOOK_SECRET=
