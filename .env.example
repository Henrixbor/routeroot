# RouteRoot Configuration
# Copy to .env and edit values

# Required
ROUTEROOT_DOMAIN=routeroot.dev
ROUTEROOT_SERVER_IP=127.0.0.1
ROUTEROOT_API_KEY=   # REQUIRED: min 16 chars. Generate with: openssl rand -hex 32

# Multi-domain (comma-separated, first is primary)
# ROUTEROOT_DOMAINS=routeroot.dev,vibeyard.io

# Optional — deployment limits
ROUTEROOT_MAX_DEPLOYMENTS=20
ROUTEROOT_DEFAULT_TTL=48h
ROUTEROOT_MAX_MEMORY=2048
ROUTEROOT_MAX_CPUS=2

# Optional — security
# ROUTEROOT_ALLOWED_REPO_HOSTS=github.com,gitlab.com,bitbucket.org

# Optional — logging
ROUTEROOT_LOG_FORMAT=human

# Optional — GitHub webhook auto-deploy
ROUTEROOT_GITHUB_WEBHOOK_SECRET=

# Internal (set by docker-compose, rarely need to override)
# ROUTEROOT_CADDY_ADMIN=http://caddy:2019
# DATABASE_PATH=/data/routeroot.db
# ZONE_FILE_DIR=/dns-zones
