# RouteRoot Configuration
# Copy to .env and edit values

# Required
ROUTEROOT_DOMAIN=routeroot.dev
ROUTEROOT_SERVER_IP=127.0.0.1
ROUTEROOT_API_KEY=change-me-to-a-secure-key

# Optional
ROUTEROOT_MAX_DEPLOYMENTS=20
ROUTEROOT_DEFAULT_TTL=48h
ROUTEROOT_MAX_MEMORY=2048
ROUTEROOT_MAX_CPUS=2
ROUTEROOT_LOG_FORMAT=human
ROUTEROOT_GITHUB_WEBHOOK_SECRET=
